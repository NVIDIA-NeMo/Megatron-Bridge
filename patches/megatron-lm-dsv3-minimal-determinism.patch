+# --- DSv3 GB200 determinism knobs (script-level via env) ---------------------
+# HYBRIDEP_SYNC (default "1"): torch.cuda.synchronize() after each non-blocking
+#   dispatch_with_permute / combine_with_unpermute. Closes a cross-stream race
+#   (consumer on the current stream reads still-in-flight comm-stream writes ->
+#   cudaErrorIllegalAddress). Set HYBRIDEP_SYNC=0 to disable.
+# HYBRIDEP_CUSTOM_ALLGATHER (default "0" = forced False): 26.04 defaults
+#   enable_custom_allgather=True, whose path leaves num_dispatched_tokens_tensor
+#   uninitialised -> "-4 dim" crash under torch.use_deterministic_algorithms.
+#   Set HYBRIDEP_CUSTOM_ALLGATHER=1 to restore stock True.
+_HYBRIDEP_SYNC_ENABLED = os.environ.get("HYBRIDEP_SYNC", "1").strip() != "0"
+_HYBRIDEP_CUSTOM_ALLGATHER = os.environ.get("HYBRIDEP_CUSTOM_ALLGATHER", "0").strip() != "0"
+
+
+def _hybridep_maybe_sync():
+    if _HYBRIDEP_SYNC_ENABLED:
+        torch.cuda.synchronize()
+
 
